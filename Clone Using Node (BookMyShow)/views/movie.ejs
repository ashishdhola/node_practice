<!-- MultipleFiles/views/movie.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie List</title>
</head>
<body>
    <h1>Movie List</h1>
    <a href="/movie/add">Add New Movie</a>
    <ul>
        <% movies.forEach(movie => { %>
            <li>
                <strong><%= movie.title %></strong> - <%= movie.director %> 
                <a href="/movie/editMovie/<%= movie._id %>">Edit</a>
                <a href="/movie/deleteMovie/<%= movie._id %>">Delete</a>
            </li>
        <% }) %>
    </ul>
</body>
</html>